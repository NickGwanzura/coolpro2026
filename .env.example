# Copy to .env.local for development. In production (Railway), set these as
# environment variables on the service — do not commit a real .env file.

# --- Database ---------------------------------------------------------------
# Neon Postgres connection string.
DATABASE_URL=

# --- Auth --------------------------------------------------------------------
# Secret used to sign session cookies (HMAC-SHA256). Generate with:
#   openssl rand -base64 32
# Required in production — the app refuses to start without it.
SESSION_SECRET=

# Set to "true" to enable the instant demo-persona login panel on /login and
# the role-only login path on POST /api/auth/login. Leave unset (disabled) in
# production. NEXT_PUBLIC_ variant controls the client-side UI toggle.
ENABLE_DEMO_LOGIN=false
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=false

# --- AI services ---------------------------------------------------------------
# Used server-side only (never exposed to the browser bundle).
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Seeding -----------------------------------------------------------------
# Must be explicitly set to "true" to allow `npm run db:seed`, which TRUNCATEs
# and reseeds core tables. Never set this against a production DATABASE_URL.
ALLOW_SEED_TRUNCATE=false

# --- Cloudflare R2 (course material storage) ---------------------------------
# S3-compatible object storage for course module attachments (PDFs, videos,
# slides). Create a bucket + API token with Object Read & Write in the
# Cloudflare dashboard (R2 > Manage API Tokens).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- WhatGas sync --------------------------------------------------------------
# Shared secret for the scheduled sync trigger (POST /api/cron/whatgas-sync).
# Generate with: openssl rand -base64 32
# Point an external scheduler (Railway Cron, GitHub Actions, cron-job.org) at
# that route with "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# --- Email & Site URL ---------------------------------------------------------
# Resend API key for transactional emails (invites, approvals, notifications).
# Create an API key at https://resend.com/api-keys.
RESEND_API_KEY=

# Public-facing URL of the deployed app. Used in email links and canonical URLs.
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=
